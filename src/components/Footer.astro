---
import siteConfig from '../../site-config.json';
---

<footer class="site-footer">
  <p class="footer-copy">{siteConfig.footer.copyright}</p>
</footer>

<style>
  .site-footer {
    padding: 4rem 2rem 2rem;
    margin-top: auto;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0;
  }
</style>
