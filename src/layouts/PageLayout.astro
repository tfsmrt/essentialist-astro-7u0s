---
import Base from './Base.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Clean title — remove " – Essentialist" suffix
const displayTitle = title.replace(/ – Essentialist$/, '');
---

<Base title={displayTitle} description={description}>
  <div class="page-wrapper">
    <Header />
    <main class="page-main">
      <div class="page-layout">
        <div class="page-title-area">
          <h1 class="page-title">{displayTitle}</h1>
        </div>
        <div class="page-body prose">
          <slot />
        </div>
      </div>
    </main>
  </div>
</Base>

<style>
  .page-wrapper {
    background-color: var(--color-surface);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .page-main {
    flex: 1;
    padding: 2rem;
  }

  .page-layout {
    max-width: 1100px;
    margin: 0 auto;
  }

  .page-title-area {
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 3.75rem; /* ~60px */
    font-weight: 700;
    line-height: var(--lh-heading);
    color: var(--color-text);
  }

  .page-body {
    max-width: 60%;
    margin-left: auto;
  }

  @media (max-width: 1024px) {
    .page-body {
      max-width: 75%;
    }
  }

  @media (max-width: 768px) {
    .page-main {
      padding: 1rem;
    }

    .page-title {
      font-size: 2.5rem;
    }

    .page-body {
      max-width: 100%;
    }
  }
</style>
