---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="Page Not Found – Essentialist" description="The page you're looking for doesn't exist.">
  <div class="error-wrapper">
    <Header />
    <main class="error-page">
      <h1 class="error-heading">Oops… this page was not found.</h1>
      <p class="error-text">It looks like nothing was found at this location. Maybe try a search?</p>
      <form class="search-form" action="/search" method="get">
        <input
          type="search"
          name="q"
          placeholder="Search…"
          class="search-input"
          aria-label="Search"
        />
        <button type="submit" class="search-btn" aria-label="Search">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </form>
    </main>
  </div>
</Base>

<style>
  .error-wrapper {
    background-color: var(--color-bg);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .error-page {
    flex: 1;
    padding: 3rem 2rem;
    max-width: 600px;
    margin: 0 auto;
    width: 100%;
  }

  .error-heading {
    font-size: 2.2rem;
    font-weight: 600;
    line-height: var(--lh-heading);
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .error-text {
    font-size: var(--size-base);
    color: var(--color-text);
    margin-bottom: 2rem;
  }

  .search-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 400px;
  }

  .search-input {
    flex: 1;
    padding: 0.6rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--size-base);
    outline: none;
    border-radius: 4px;
  }

  .search-input::placeholder {
    color: var(--color-muted);
  }

  .search-input:focus {
    border-color: var(--color-primary);
  }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 0.75rem;
    background-color: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.2s ease;
    flex-shrink: 0;
  }

  .search-btn:hover {
    background-color: var(--color-primary-hover);
  }

  .search-btn svg {
    display: block;
    stroke: #fff;
  }
</style>
